@init
ext_noinit = 1;
gfx_ext_retina = 1;
mouse_sensivity();
srate_old = srate;


lfile = -1;
wavebuf = 100000;
wavechn = 0;
wavelen = 0;
wavesrate = 0;
last_clicked_pad = 1;

uncoupled_hats = 1;
//MAX 5s Samples! at least in Stereo, in 96kHz
dummy_slot = 319.840;
slot_start = 1279840;
pad01.meta = slot_start;
pad01.buf = pad01.meta + 10;
pad02.meta = pad01.buf + 1920000;
pad02.buf = pad02.meta + 10;
pad03.meta = pad02.buf + 1920000;
pad03.buf = pad03.meta + 10;
pad04.meta = pad03.buf + 1920000;
pad04.buf = pad04.meta + 10;
pad05.meta = pad04.buf + 1920000;
pad05.buf = pad05.meta + 10;
pad06.meta = pad05.buf + 1920000;
pad06.buf = pad06.meta + 10;
pad07.meta = pad06.buf + 1920000;
pad07.buf = pad07.meta + 10;
pad08.meta = pad07.buf + 1920000;
pad08.buf = pad08.meta + 10;
pad09.meta = pad08.buf + 1920000;
pad09.buf = pad09.meta + 10;
pad10.meta = pad09.buf + 1920000;
pad10.buf = pad10.meta + 10;
pad11.meta = pad10.buf + 1920000;
pad11.buf = pad11.meta + 10;
pad12.meta = pad11.buf + 1920000;
pad12.buf = pad12.meta + 10;
pad13.meta = pad12.buf + 1920000;
pad13.buf = pad13.meta + 10;
pad14.meta = pad13.buf + 1920000;
pad14.buf = pad14.meta + 10;
pad15.meta = pad14.buf + 1920000;
pad15.buf = pad15.meta + 10;
pad16.meta = pad15.buf + 1920000;
pad16.buf = pad16.meta + 10;





function outmeter () (
max(abs(this.spl0),abs(this.spl1)) >= this.outmeter ? this.outmeter = max(abs(this.spl0),abs(this.spl1)) : this.outmeter *= db2ratio(-120/srate);
this.outmeter >= 1 ? this.clip = srate/10;
this.clip = max(0, this.clip-1);
//this.rms_sum -= this.rms_meter[this.i]*this.rms_meter[this.i];
//this.rms_meter[this.i] = abs(input);
//this.rms_sum += this.rms_meter[this.i]*this.rms_meter[this.i];
//this.rms_meter_result = sqrt(this.rms_sum/rms_size);
//this.i += 1;
//this.i >= rms_size ? this.i = 0;
);




//pad01.buf_R = pad01.buf_buf_L +  960.000;
function explog (input, factor) (
input^factor; // 1=linear, < 1 = log (schnell rein), > 1 = exp (langsam rein)
);


function read_file(filehandle)
local (len)
(
  filehandle > 0 ? (
    len = file_avail(filehandle);
    
    file_riff(filehandle, wavechn, wavesrate);
    last_len = len;
    !load_all ? (
    this == 1 ? #pad01name = #filestr;
    this == 2 ? #pad02name = #filestr;
    this == 3 ? #pad03name = #filestr;
    this == 4 ? #pad04name = #filestr;
    this == 5 ? #pad05name = #filestr;
    this == 6 ? #pad06name = #filestr;
    this == 7 ? #pad07name = #filestr;
    this == 8 ? #pad08name = #filestr;
    this == 9 ? #pad09name = #filestr;
    this == 10? #pad10name = #filestr;
    this == 11? #pad11name = #filestr;
    this == 12? #pad12name = #filestr;
    this == 13? #pad13name = #filestr;
    this == 14? #pad14name = #filestr;
    this == 15? #pad15name = #filestr;
    this == 16? #pad16name = #filestr;
    );
    this.srate = wavesrate;
    this.wavechn = wavechn;
    this.ms_length = (last_len/last_wavechn)/last_srate;
    file_rewind(filehandle);
    wavesrate = 2*srate;//wavesrate * (1024 / len);
    file_riff(filehandle, wavechn='rqsr', wavesrate); // resample wave at 1024 length
    this.mode = -1;
    wavechn == 1 ? (
    wavebuf = this.buf;
      wavelen_in = file_avail(filehandle);
      wavelen = min(wavelen_in,1920000);
      file_mem(filehandle,wavebuf+wavelen,wavelen);
      this.store_length = wavelen;
      this.length = 2*wavelen / wavechn;
      //my_len = 0.25*pad01.length / srate;
      mono_loop = 0;
      loop(wavelen,
        wavebuf[mono_loop*2] = wavebuf[wavelen+mono_loop];
        wavebuf[mono_loop*2+1] = wavebuf[wavelen+mono_loop];
        wavebuf[wavelen+mono_loop] = 0;
        mono_loop += 1;
      );
      this.mode = 1;
      S_BD == this ? S_BD = 0 :
      S_SN == this ? S_SN = 0 :
      S_Clap == this ? S_Clap = 0 :
      S_cym == this ? S_Cym = 0 :
      S_Hat == this ? S_Hat = 0 :
      S_oHat == this ? S_oHat = 0 :
      S_T3 == this ? S_T3 = 0 :
      S_T2 == this ? S_T2 = 0 :
      S_T1 == this ? S_T1 = 0 :
      S_Rim == this ? S_Rim = 0 :
      S_CB == this ? S_CB = 0 :
      S_Shaker == this ? S_Shaker = 0 ;
      !load_all ? (
      this.start_handle = 0;
      this.stop_handle = this.length/4;
      this.fade_in_handle = 0;
      this.fade_out_handle = 0;
      this.holds_data = 1;
      this.swapLR = 0;
      slider(3 + 1 + (this-1)*7) = 1;
      slider(3 + 2 + (this-1)*7) = 0.5;
      slider(3 + 3 + (this-1)*7) = 5;
      slider(3 + 4 + (this-1)*7) = 5;
      slider(3 + 5 + (this-1)*7) = 0;
      slider(3 + 6 + (this-1)*7) = 0;
      slider(3 + 7 + (this-1)*7) = 100;
      slider(115+this) = 0;
      caller = 1;
      );
    ): wavechn == 2 ? (
    wavebuf = this.buf;
      wavelen_in = file_avail(filehandle);
      wavelen = min(wavelen_in,1920000);
      file_mem(filehandle,wavebuf,wavelen);
      this.store_length = wavelen;
      this.length = 2*wavelen / wavechn;
      //my_len = 0.25*pad01.length / srate;
      this.mode = 1;
      S_BD == this ? S_BD = 0 :
      S_SN == this ? S_SN = 0 :
      S_Clap == this ? S_Clap = 0 :
      S_cym == this ? S_Cym = 0 :
      S_Hat == this ? S_Hat = 0 :
      S_oHat == this ? S_oHat = 0 :
      S_T3 == this ? S_T3 = 0 :
      S_T2 == this ? S_T2 = 0 :
      S_T1 == this ? S_T1 = 0 :
      S_Rim == this ? S_Rim = 0 :
      S_CB == this ? S_CB = 0 :
      S_Shaker == this ? S_Shaker = 0 ;
      !load_all ? (
      this.start_handle = 0;
      this.stop_handle = this.length/4;
      this.fade_in_handle = 0;
      this.fade_out_handle = 0;
      this.holds_data = 1;
      this.swapLR = 0;
      slider(3 + 1 + (this-1)*7) = 1;
      slider(3 + 2 + (this-1)*7) = 0.5;
      slider(3 + 3 + (this-1)*7) = 5;
      slider(3 + 4 + (this-1)*7) = 5;
      slider(3 + 5 + (this-1)*7) = 0;
      slider(3 + 6 + (this-1)*7) = 0;
      slider(3 + 7 + (this-1)*7) = 100;
      slider(115+this) = 0;
      caller = 1;
      );
    );
    file_close(filehandle);
    burn_in_srate = srate;
    //filehandle_ = 0;
    fileopen = 0;
  );
);


function read_file_string(str) (
  fileopen = 1;
  filehandle_=file_open(#filestr);
  filehandle_ < 0 ? (this.mode = -1; file_close(#filestr)) : this.read_file(filehandle_);
);


