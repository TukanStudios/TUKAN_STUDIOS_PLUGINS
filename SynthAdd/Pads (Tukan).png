confirm_me == 0 && mouseClick == 1 && g_collision(gfx_x, gfx_y, 30*zoom, 30*zoom) ? (Kick_Type = 0; caller = 1);
g_collision(gfx_x, gfx_y, 30*zoom, 30*zoom) ? #tooltip += " Choose from 4 different bassdrum types.";
gfx_drawstr("I", 0x05, gfx_x+30*zoom, gfx_y + 30*zoom);

gfx_x = 1035*zoom; gfx_y = 420*zoom;
black();
gfx_rect(gfx_x, gfx_y, 30*zoom, 30*zoom);
Kick_Type == 1 ? rgb(30,250,30) : rgb(170,170,170);
