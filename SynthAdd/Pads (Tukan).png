gfx_rect(scroll_x=box_x + box_scroll * (box_w -(box_w/(box_hzoom*19 + 1))), scroll_y=box_y + box_h + 2*zoom, scroll_w=box_w/(box_hzoom*19 + 1), scroll_h=10*zoom);


function start_handle_dragstart() (
gen_dragging = 1;
  start_handle_old = this.start_handle;
  mouse_x_old = mouse_x;
  ctrl ? (
    this.start_handle = 0;
  ):(
    start_handle_dragging = 1;
  );
  update_wave = 1;
);

function start_handle_drag() (
  mouse_x > box_x-1 && mouse_x < box_x + box_w ? this.start_handle = floor(((mouse_x-box_x)/box_w) * box_time_samples + box_start_samples/4);
  this.start_handle = min(this.stop_handle, this.start_handle);
  update_wave = 1;
);

function fade_in_handle_dragstart() (
gen_dragging = 1;
  fade_in_handle_old = this.fade_in_handle;
  mouse_x_old = mouse_x;
  ctrl ? (
    this.fade_in_handle = 0;
  ):(
    fade_in_handle_dragging = 1;
  );
  update_wave = 1;
);

function fade_in_handle_drag() (
  mouse_x > box_x-1 && mouse_x < box_x + box_w+1 ? this.fade_in_handle = floor(((mouse_x-box_x)/box_w) * box_time_samples + box_start_samples/4) - this.start_handle;
  this.fade_in_handle = max(this.fade_in_handle, 0);
  update_wave = 1;
);


function stop_handle_dragstart() (
gen_dragging = 1;
  stop_handle_old = this.stop_handle;
  mouse_x_old = mouse_x;
  ctrl ? (
    this.stop_handle = this.length/4;
  ):(
    stop_handle_dragging = 1;
  );
  update_wave = 1;
);

function stop_handle_drag() (
  mouse_x > box_x && mouse_x < box_x + box_w+1 ? this.stop_handle = floor(((mouse_x-box_x)/box_w) * box_time_samples + box_start_samples/4);
  this.stop_handle = max(this.stop_handle, this.start_handle);
  update_wave = 1;
);

function fade_out_handle_dragstart() (
gen_dragging = 1;
  fade_out_handle_old = this.fade_out_handle;
  mouse_x_old = mouse_x;
  ctrl ? (
    this.fade_out_handle = 0;
  ):(
    fade_out_handle_dragging = 1;
  );
  update_wave = 1;
);

function fade_out_handle_drag() (
  mouse_x > box_x-1 && mouse_x < box_x + box_w+1 ? this.fade_out_handle = this.stop_handle - floor(((mouse_x-box_x)/box_w) * box_time_samples + box_start_samples/4);
  this.fade_out_handle = max(this.fade_out_handle, 0);
  update_wave = 1;
);


confirm_me == 0 && mouseClick == 1 && view == 0 ? (

  !soundless ? (
  g_collision(pad01.x, pad01.y, pads_size, pads_size) ? (pad01.play_velocity = 127*((pad01.y+pads_size)-mouse_y)/pads_size;pad01.play = 1; pad01.relvol = 1; pad01.pos = pad01.start_handle*2; last_clicked_pad = 1);
  g_collision(pad02.x, pad02.y, pads_size, pads_size) ? (pad02.play_velocity = 127*((pad02.y+pads_size)-mouse_y)/pads_size;pad02.play = 1; pad02.relvol = 1; pad02.pos = pad02.start_handle*2; last_clicked_pad = 2);
  g_collision(pad03.x, pad03.y, pads_size, pads_size) ? (pad03.play_velocity = 127*((pad03.y+pads_size)-mouse_y)/pads_size;pad03.play = 1; pad03.relvol = 1; pad03.pos = pad03.start_handle*2; last_clicked_pad = 3);
