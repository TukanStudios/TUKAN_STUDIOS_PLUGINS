    S_CB == this ? S_CB = 0 :
    S_Shaker == this ? S_Shaker = 0 ;
  );
);
);
rgb(170,170,170);
gfx_drawstr(#mode, 0x05, gfx_x+110*zoom, gfx_y + 24*zoom);


/*
slider132:kick_type=0<0,3,1>-Kick Type
slider133:_kick_pitch_decay=0.7<0,1,.00001>                 -Kick Pitch Decay
