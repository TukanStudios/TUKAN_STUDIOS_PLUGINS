function pad_color() (
//this.mode == 1 ? rgb(180,180,220) : rgb(70,70,70);
this.mode == 1 ? rgb(170,174,255) : rgb(70,70,70);
this.mode == -1 ? rgb(120,0,0);
this.mode > 1 ? rgb(255, 173, 0); //rgb(197, 245, 185);
this.play >= 1 && this.play <= 1.1 ? (pad_on = 1*animate_pads):(pad_on=0); //rgb(30,220,30);
this == last_clicked_pad ? (gfx_r*=1.2; gfx_b*=1.2; gfx_g*=1.2);
);


pads_x = 35*zoom;
pads_y = 120*zoom;
pads_space = 10*zoom;
pads_size = 80*zoom;

