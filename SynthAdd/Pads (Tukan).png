@block
caller == 1 ? on_slider();


srate != srate_old && !burn_in ? load_all = 1;
burn_in && srate != burn_in_srate ? plugin_blocked = 1 : plugin_blocked = 0;
srate_old = srate;

while (midirecv(offset, msg1, note, vel)) (

  event = msg1 & 0xF0;
  channel = msg1 & 0x0F;
  
  event == 176 && note == 1 ? norm_modwheel = vel/127;
  event == 224 ? norm_pitchwheel = vel > 64 ? (vel-64)/63 : (vel-64)/64;
  event == 208 ? norm_aftertouch = note / 137;
  event == 176 && note == 64 ? (vel == 127 ? sus_pedal = 1 : sus_pedal = 0);
  // Note on
  event == 0x90 && vel ? (

    //ptr[0] = note;
    //ptr[1] = vel / 127;
    note == pad01.note ? (pad01.relvol = 1; pad01.play = 1; pad01.play_velocity = vel; pad01.pos = pad01.start_handle*2);
    note == pad02.note ? (pad02.relvol = 1; pad02.play = 1; pad02.play_velocity = vel; pad02.pos = pad02.start_handle*2);
    note == pad03.note ? (pad03.relvol = 1; pad03.play = 1; pad03.play_velocity = vel; pad03.pos = pad03.start_handle*2);
    note == pad04.note ? (pad04.relvol = 1; pad04.play = 1; pad04.play_velocity = vel; pad04.pos = pad04.start_handle*2);
    note == pad05.note ? (pad05.relvol = 1; pad05.play = 1; pad05.play_velocity = vel; pad05.pos = pad05.start_handle*2);
    note == pad06.note ? (pad06.relvol = 1; pad06.play = 1; pad06.play_velocity = vel; pad06.pos = pad06.start_handle*2);
    note == pad07.note ? (pad07.relvol = 1; pad07.play = 1; pad07.play_velocity = vel; pad07.pos = pad07.start_handle*2);
    note == pad08.note ? (pad08.relvol = 1; pad08.play = 1; pad08.play_velocity = vel; pad08.pos = pad08.start_handle*2);
    note == pad09.note ? (pad09.relvol = 1; pad09.play = 1; pad09.play_velocity = vel; pad09.pos = pad09.start_handle*2);
    note == pad10.note ? (pad10.relvol = 1; pad10.play = 1; pad10.play_velocity = vel; pad10.pos = pad10.start_handle*2);
    note == pad11.note ? (pad11.relvol = 1; pad11.play = 1; pad11.play_velocity = vel; pad11.pos = pad11.start_handle*2);
    note == pad12.note ? (pad12.relvol = 1; pad12.play = 1; pad12.play_velocity = vel; pad12.pos = pad12.start_handle*2);
    note == pad13.note ? (pad13.relvol = 1; pad13.play = 1; pad13.play_velocity = vel; pad13.pos = pad13.start_handle*2);
    note == pad14.note ? (pad14.relvol = 1; pad14.play = 1; pad14.play_velocity = vel; pad14.pos = pad14.start_handle*2);
    note == pad15.note ? (pad15.relvol = 1; pad15.play = 1; pad15.play_velocity = vel; pad15.pos = pad15.start_handle*2);
    note == pad16.note ? (pad16.relvol = 1; pad16.play = 1; pad16.play_velocity = vel; pad16.pos = pad16.start_handle*2);
        
  );
  
  // Note off
  event == 0x80 || (event == 0x90 && !vel) ? (
      pad01.hold && note == pad01.note ? (pad01.play = 2);
      pad02.hold && note == pad02.note ? (pad02.play = 2);
      pad03.hold && note == pad03.note ? (pad03.play = 2);
      pad04.hold && note == pad04.note ? (pad04.play = 2);
      pad05.hold && note == pad05.note ? (pad05.play = 2);
      pad06.hold && note == pad06.note ? (pad06.play = 2);
      pad07.hold && note == pad07.note ? (pad07.play = 2);
      pad08.hold && note == pad08.note ? (pad08.play = 2);
      pad09.hold && note == pad09.note ? (pad09.play = 2);
      pad10.hold && note == pad10.note ? (pad10.play = 2);
      pad11.hold && note == pad11.note ? (pad11.play = 2);
      pad12.hold && note == pad12.note ? (pad12.play = 2);
      pad13.hold && note == pad13.note ? (pad13.play = 2);
      pad14.hold && note == pad14.note ? (pad14.play = 2);
      pad15.hold && note == pad15.note ? (pad15.play = 2);
      pad16.hold && note == pad16.note ? (pad16.play = 2);
      !pad01.hold && note == pad01.note ? (pad01.play = 1.5);
      !pad02.hold && note == pad02.note ? (pad02.play = 1.5);
      !pad03.hold && note == pad03.note ? (pad03.play = 1.5);
      !pad04.hold && note == pad04.note ? (pad04.play = 1.5);
      !pad05.hold && note == pad05.note ? (pad05.play = 1.5);
      !pad06.hold && note == pad06.note ? (pad06.play = 1.5);
      !pad07.hold && note == pad07.note ? (pad07.play = 1.5);
      !pad08.hold && note == pad08.note ? (pad08.play = 1.5);
      !pad09.hold && note == pad09.note ? (pad09.play = 1.5);
      !pad10.hold && note == pad10.note ? (pad10.play = 1.5);
      !pad11.hold && note == pad11.note ? (pad11.play = 1.5);
      !pad12.hold && note == pad12.note ? (pad12.play = 1.5);
      !pad13.hold && note == pad13.note ? (pad13.play = 1.5);
      !pad14.hold && note == pad14.note ? (pad14.play = 1.5);
      !pad15.hold && note == pad15.note ? (pad15.play = 1.5);
      !pad16.hold && note == pad16.note ? (pad16.play = 1.);
  );

  // All notes off
  event == 0xB0 && note == 123 ? (
    do_nothing = 0;
  );

  midisend(offset, msg1, note, vel);
);

load_all ? load_alle();


israte = 1.0 / srate;
invblock = 1.0 / samplesblock;
hsrate = 0.5 * srate; 
sample_ratio = 48000 / srate;
time_factor = 2302.58509299 / srate; // - ln(0.1) * 1000 (since we want to work in ms)
kick_bottom = log((20 + 80 * kick_tune)/22050);
snare_bottom = log((170 + 230 * snare_tune)/22050);

(last_reinit_state != sample_ratio) ? (
  reinit();
  last_reinit_state = sample_ratio;
);


@sample


function wave_spline3(landr)
  instance(buf, size, t)
  local(x, i, j, y0, y1, y2, y3, a0, a1, a2, a3, result)
(
  //x = t * size;
  //this.wave_inc();
  result = 0;
  //landr == 1 ? 
  x = this.pos; //TK
  //landr == 2 ? x = this.pos+1; //TK
  
  i = floor(x);//x|0;
  x -= i;

  j = i - 1; 
    j < 0 ? result = 1;//j += size; 
  y0 = buf[j*2+landr];
  y1 = buf[i*2+landr];
  i += 1; i >= this.stop_handle*2 ? result = 1; 
  y2 = buf[i*2+landr];
  i += 1; i >= this.stop_handle*2 ? result = 1; 
  y3 = buf[i*2+landr];

  a0 = 0.5*(y1 - y2) + 1/6*(y3 - y0);
  a1 = 0.5*(y0 + y2) - y1;
  a2 = 0.5*(y2 - y0);
  a3 = 1/6*(y0 + y2) + 2/3*y1;
  
  result == 1 ? buf[i*2+landr] :  x*(x*(x*a0 + a1) + a2) + a3;
);


function play_pad() (
this.mode == 1 ? (
this.relvol <= 0 ? this.play = 0;
this.outvel = (this.play_velocity/127) * (this.velocity/100)  +  1 - (this.velocity/100);
this.FIoutput = 1;
this.FOoutput = 1;
    this.play ? (
      this.pos < this.fade_in_handle*2 + this.start_handle*2 ? (
        this.FIoutput = -1*explog(1-(this.pos - this.start_handle*2) / (this.fade_in_handle*2), this.FI_coef)+1;
      );
      this.pos > this.stop_handle*2 - this.fade_out_handle*2 ? (
        this.FOoutput = 1-explog((this.pos - (this.stop_handle*2 - this.fade_out_handle*2)) / (this.fade_out_handle*2), this.FO_coef);
      );
      
      this.play == 2 ? (
        this.relvol -= 1 / (this.release * 0.25*this.length);
      );
      
      !this.swapLR ? (
        this.spl0 = this.relvol*this.outvel*this.volume*sqrt(1-this.Pan)*this.FIoutput*this.FOOutput*this.wave_spline3(0);//this.buf[2*floor(this.pos)];
        this.spl1 = this.relvol*this.outvel*this.volume*sqrt(this.Pan)*this.FIoutput*this.FOOutput*this.wave_spline3(1);//this.buf[2*floor(this.pos)+1];
      ):(
        this.spl1 = this.relvol*this.outvel*this.volume*sqrt(this.Pan)*this.FIoutput*this.FOOutput*this.wave_spline3(0);//this.buf[2*floor(this.pos)];
        this.spl0 = this.relvol*this.outvel*this.volume*sqrt(1-this.Pan)*this.FIoutput*this.FOOutput*this.wave_spline3(1);//this.buf[2*floor(this.pos)+1];
      );
      
      gen_solo && !this.solo ? this.spl0 = this.spl1 = 0;
      this.mute && !this.solo ? this.spl0 = this.spl1 = 0;
      this.pos += 2*this.speed;
      this.pos > this.stop_handle*2 ? this.play = 0;
    ):(
    this.spl0 = this.spl1 = 0;
    );
): this.mode == 2 ? (
  this.outvel = (this.play_velocity/127) * (Kick_velocity/100)  +  1 - (Kick_velocity/100);
  this.play == 1 ? (kick.kick_update(this.play_velocity); kick.kick_reset(); this.play = 1.1);
  kick.alive ? kick.check_alive(kick.kick_tick()) : this.play=0;
  this.spl0 = db2ratio(_kick_gain)*kick.left_out*this.outvel*sqrt(1-(_kick_pan+1)/2);
  this.spl1 = db2ratio(_kick_gain)*kick.right_out*this.outvel*sqrt((_kick_Pan+1)/2);
  gen_solo && !this.solo ? this.spl0 = this.spl1 = 0;
  this.mute && !this.solo ? this.spl0 = this.spl1 = 0;
): this.mode == 3 ? (
  this.outvel = (this.play_velocity/127) * (Snare_velocity/100)  +  1 - (Snare_velocity/100);
  this.play == 1 ? (Snare.snare_update(this.play_velocity); Snare.snare_reset(); this.play = 1.1);
  snare.alive ? Snare.check_alive(Snare.Snare_tick()) : this.play=0;
  this.spl0 = db2ratio(_Snare_gain)*snare.left_out*this.outvel*sqrt(1-(_snare_pan+1)/2);
  this.spl1 = db2ratio(_Snare_gain)*snare.right_out*this.outvel*sqrt((_snare_Pan+1)/2);
  gen_solo && !this.solo ? this.spl0 = this.spl1 = 0;
  this.mute && !this.solo ? this.spl0 = this.spl1 = 0;
): this.mode == 4 ? (
  this.outvel = (this.play_velocity/127) * (clap_velocity/100)  +  1 - (clap_velocity/100);
  this.play == 1 ? (clap.clap_update(this.play_velocity); clap.clap_reset(); this.play = 1.1);
  clap.alive ? clap.check_alive(clap.clap_tick()) : this.play=0;
  this.spl0 = db2ratio(_clap_gain)*clap.left_out*this.outvel*sqrt(1-(_clap_pan+1)/2);
  this.spl1 = db2ratio(_clap_gain)*clap.right_out*this.outvel*sqrt((_clap_Pan+1)/2);
  gen_solo && !this.solo ? this.spl0 = this.spl1 = 0;
  this.mute && !this.solo ? this.spl0 = this.spl1 = 0;
): this.mode == 5 ? (
  this.outvel = (this.play_velocity/127) * (ride_velocity/100)  +  1 - (ride_velocity/100);
  this.play == 1 ? (ride.ride_update(this.play_velocity); ride.ride_reset(); this.play = 1.1);
  ride.alive ? ride.check_alive(ride.ride_tick()) : this.play=0;
  this.spl0 = db2ratio(_ride_gain)*ride.left_out*this.outvel*sqrt(1-(_ride_pan+1)/2);
  this.spl1 = db2ratio(_ride_gain)*ride.right_out*this.outvel*sqrt((_ride_Pan+1)/2);
  gen_solo && !this.solo ? this.spl0 = this.spl1 = 0;
  this.mute && !this.solo ? this.spl0 = this.spl1 = 0;
): this.mode == 6 ? (
  this.outvel = (this.play_velocity/127) * (hat_velocity/100)  +  1 - (hat_velocity/100);
  this.play == 1 ? (hat.hat_update(this.play_velocity); hat.hat_reset(1, hat_attack, hat_decay, hat_tone, hat_type, hat_body); this.play = 1.1);
  hat.alive ? hat.check_alive(hat.hat_tick()) : this.play=0;
  this.spl0 = db2ratio(_hat_gain)*hat.left_out*this.outvel*sqrt(1-(_hat_pan+1)/2);
  this.spl1 = db2ratio(_hat_gain)*hat.right_out*this.outvel*sqrt((_hat_Pan+1)/2);
  gen_solo && !this.solo ? this.spl0 = this.spl1 = 0;
  this.mute && !this.solo ? this.spl0 = this.spl1 = 0;
): this.mode == 7 ? (
  this.outvel = (this.play_velocity/127) * (open_hat_velocity/100)  +  1 - (open_hat_velocity/100);
