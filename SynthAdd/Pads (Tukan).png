IC.addknob(170,170,170,0);
#readout = sprintf(#, "%.2f", slider(OC.slider));
#label1 = "OUT";
OC.addknob(170,170,170,0);


this.hold ? #readout = sprintf(#, "%.0f", 1000*slider(rel.slider)* box_length/(2*srate)) : #readout = "TRIG";
#label1 = "RELEASE";
this.hold ? Rel.addknob(170,170,170,0) : Rel.addknob(130,130,130,1);

gfx_x = rel.xIn*zoom + 80*zoom;
gfx_y = rel.yIn*zoom + 7*zoom;
ledon = !this.hold;
gfx_blit(0,zoom/2,0,0,ledon*80,80,80);
confirm_me == 0 && mouseClick == 1 && g_collision(gfx_x,gfx_y, 40*zoom,40*zoom) ? (this.hold == 1 ? this.hold = 0 : this.hold = 1; caller = 1; soundless = 1);
g_collision(gfx_x, gfx_y, 40*zoom, 40*zoom) ? #tooltip += " Trigger = plays whole pad. No Trigger = playback stops at midi note off (release).";
black(); gfx_y+=40*zoom;
gfx_drawstr("TRIG", 0x05, gfx_x+40*zoom, gfx_y + 24*zoom);

gfx_x = rel.xIn*zoom + 130*zoom;
gfx_y = rel.yIn*zoom + 7*zoom;
ledon = last_clicked_is_swapped = this.swapLR;
gfx_blit(0,zoom/2,0,0,ledon*80,80,80);
confirm_me == 0 && mouseClick == 1 && g_collision(gfx_x,gfx_y, 40*zoom,40*zoom) ? (this.swapLR == 1 ? this.swapLR = 0 : this.swapLR = 1; caller = 1; soundless = 1);
g_collision(gfx_x, gfx_y, 40*zoom, 40*zoom) ? #tooltip += " Swap left and right channel.";
black(); gfx_y+=40*zoom;
gfx_drawstr("R - L", 0x05, gfx_x+40*zoom, gfx_y + 24*zoom);
); // mode == 0


this.mode == 0 ? #mode = "OFF" :
this.mode == 1 ? #mode = "SAMPLE" :
this.mode == 2 ? #mode = "Synth Kick" :
this.mode == 3 ? #mode = "Synth Snare" :
this.mode == 4 ? #mode = "Synth Clap" :
this.mode == 5 ? #mode = "Synth Cymbal" :
this.mode == 6 ? #mode = "Synth Hihat" :
this.mode == 7 ? #mode = "Synth Open HH" :
this.mode == 8 ? #mode = "Synth L-Tom" :
this.mode == 9 ? #mode = "Synth M-Tom" :
this.mode ==10 ? #mode = "Synth H-Tom" :
this.mode ==11 ? #mode = "Synth Rim" :
this.mode ==12 ? #mode = "Synth Cowbell" :
this.mode ==13 ? #mode = "Synth Shaker" ;

black();
gfx_rect(gfx_x = rel.xin*zoom + 70*zoom, gfx_y = rel.yin * zoom - 20*zoom, 110*zoom, 20*zoom);
g_collision(gfx_x, gfx_y, 110*zoom, 20*zoom) ? #tooltip += " Choose Pad-mode. (Synth-Drums can only be assigned to one pad at once)";
confirm_me == 0 && MouseClick == 1 && g_collision(gfx_x, gfx_y, 110*zoom, 20*zoom) ? (
this.mode == 0 ? #menu = "!OFF|" : #menu = "OFF|";
this.mode == 1 ? #menu += "!Sample|" : #menu += "Sample|";
this.mode == 2 ? #menu += "!"; #menu += "Synth Kick"; S_BD != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_BD); #menu += ")"); #menu += "|";
this.mode == 3 ? #menu += "!"; #menu += "Synth Snare"; S_SN != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_SN); #menu += ")"); #menu += "|";
this.mode == 4 ? #menu += "!"; #menu += "Synth Clap"; S_Clap != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_Clap); #menu += ")"); #menu += "|";
this.mode == 5 ? #menu += "!"; #menu += "Synth Cymbal"; S_Cym != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_Cym); #menu += ")"); #menu += "|";
this.mode == 6 ? #menu += "!"; #menu += "Synth Hihat"; S_Hat != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_Hat); #menu += ")"); #menu += "|";
this.mode == 7 ? #menu += "!"; #menu += "Synth Open Hihat"; S_oHat != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_oHat); #menu += ")"); #menu += "|";
this.mode == 8 ? #menu += "!"; #menu += "Synth Low Tom"; S_T3 != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_T3); #menu += ")"); #menu += "|";
this.mode == 9 ? #menu += "!"; #menu += "Synth Mid tom"; S_T2 != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_T2); #menu += ")"); #menu += "|";
this.mode == 10? #menu += "!"; #menu += "Synth High Tom"; S_T1 != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_T1); #menu += ")"); #menu += "|";
this.mode == 11? #menu += "!"; #menu += "Synth Rim"; S_Rim != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_Rim); #menu += ")"); #menu += "|";
this.mode == 12? #menu += "!"; #menu += "Synth Cowbell"; S_CB != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_CB); #menu += ")"); #menu += "|";
this.mode == 13? #menu += "!"; #menu += "Synth Shaker"; S_Shaker != 0 ? (#menu += " (Pad "; #menu += sprintf(#, "%i", S_Shaker); #menu += ")"); #menu += "|";
last_clicked_item = gfx_showmenu(#menu);
last_clicked_item ? (
  last_clicked_item -= 1;
  last_clicked_item == 0 ? this.mode = 0:
  last_clicked_item == 1 ? (this.holds_data ? this.mode = 1 : this.mode = 0) :
  last_clicked_item == 2 ? (S_BD == 0 ? this.mode = 2; S_BD = this):
  last_clicked_item == 3 ? (S_SN == 0 ? this.mode = 3; S_SN = this):
  last_clicked_item == 4 ? (S_Clap == 0 ? this.mode = 4; S_Clap = this):
  last_clicked_item == 5 ? (S_Cym == 0 ? this.mode = 5; S_Cym = this):
  last_clicked_item == 6 ? (S_Hat == 0 ? this.mode = 6; S_Hat = this):
