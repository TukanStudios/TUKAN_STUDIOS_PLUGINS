function solo_mute() (

pads_meters ? (
this.clip ? rgb(255,30,100) : rgb(30,255,100); gfx_x = this.x+pads_size+2*zoom; gfx_y = this.y+pads_size;
gfx_rectto(gfx_x+max(1,3*zoom),max(min(gfx_y,this.y-pads_size*ratio2db(this.outmeter)/60),this.y));
);

this.mode == -1 ? (
  gfx_x = this.x+offset; gfx_y = this.y+offset;
  rgb(160,160,160);
  gfx_drawstr("NO SAMPLE", 0x05, gfx_x+pads_size-4*zoom, gfx_y + pads_size);
);

this.mode > 0 ? (
this.play == 1 || this.play == 1.1 ? offset = animate_pads*1*zoom : offset = 0;
this.mute == 1 ? (rgb(255,20,20);fill = 1) : (rgb(140,140,140);fill=0);
gfx_rect(gfx_x = this.x + 58*zoom+offset, gfx_y=this.y + 5*zoom+offset, 15*zoom,15*zoom,fill);
confirm_me == 0 && mouseClick == 1 && g_collision(gfx_x,gfx_y, 15*zoom,15*zoom) ? (this.mute == 1 ? this.mute = 0 : this.mute = 1; caller = 1; soundless = 1);
this.mute ? white() : black(); 
gfx_x += 2*zoom; gfx_drawstr("M");
this.solo == 1 ? (rgb(255,255,20);fill=1) : (rgb(140,140,140);fille=0);
gfx_rect(gfx_x = this.x + 38*zoom+offset, gfx_y=this.y + 5*zoom+offset, 15*zoom,15*zoom,fill);
confirm_me == 0 && mouseClick == 1 && g_collision(gfx_x,gfx_y, 15*zoom,15*zoom) ? (this.solo == 1 ? this.solo = 0 : this.solo = 1; caller = 1; soundless = 1);
black(); 
gfx_x += 3*zoom; gfx_drawstr("S");

this.mode == 0 ? #padlabel = "" :
this.mode == 1 ? #padlabel = "wav" :
this.mode == 2 ? #padlabel = "BD" :
this.mode == 3 ? #padlabel = "SN" :
this.mode == 4 ? #padlabel = "CLP" :
this.mode == 5 ? #padlabel = "CYM" :
this.mode == 6 ? #padlabel = "CH" :
this.mode == 7 ? #padlabel = "OH" :
this.mode == 8 ? #padlabel = "T3" :
this.mode == 9 ? #padlabel = "T2" :
this.mode ==10 ? #padlabel = "T1" :
this.mode ==11 ? #padlabel = "RM" :
this.mode ==12 ? #padlabel = "CB" :
this.mode ==13 ? #padlabel = "SH" ;
gfx_x = this.x+offset;gfx_y = this.y + pads_size - 20*zoom + offset;
padlabel != "" ? gfx_drawstr(#padlabel, 0x02, gfx_x+pads_size-4*zoom, gfx_y + 24*zoom);

/*
this.hold == 1 ? (rgb(255,150,0);fill=1) : (rgb(140,140,140);fille=0);
gfx_rect(gfx_x = this.x + 58*zoom+offset, gfx_y=this.y + 25*zoom+offset, 15*zoom,15*zoom,fill);
mouseClick == 1 && g_collision(gfx_x,gfx_y, 15*zoom,15*zoom) ? (this.hold == 1 ? this.hold = 0 : this.hold = 1; caller = 1; soundless = 1);
black(); 
gfx_x += 3*zoom; this.hold == 1 ? gfx_drawstr("H") : gfx_drawstr("T");
*/
(this.note - 0)%12 == 0 ? #readouts = "C";
(this.note - 0)%12 == 1 ? #readouts = "C#";
(this.note - 0)%12 == 2 ? #readouts = "D";
(this.note - 0)%12 == 3 ? #readouts = "D#";
(this.note - 0)%12 == 4 ? #readouts = "E";
(this.note - 0)%12 == 5 ? #readouts = "F";
(this.note - 0)%12 == 6 ? #readouts = "F#";
(this.note - 0)%12 == 7 ? #readouts = "G";
(this.note - 0)%12 == 8 ? #readouts = "G#";
(this.note - 0)%12 == 9 ? #readouts = "A";
(this.note - 0)%12 == 10 ? #readouts = "Bb";
(this.note - 0)%12 == 11 ? #readouts = "B";
sprintf(#readoutsoctave, "%i", (abs(this.note)-12)/12   ); #readouts += #readoutsoctave;
gfx_x = this.x + 5*zoom + offset; gfx_y = this.y + pads_size - 20*zoom + offset;
//gfx_rect(gfx_x,gfx_y,23*zoom,15*zoom,0);
confirm_me == 0 && mouseClickR == 2 && g_collision(gfx_x,gfx_y,23*zoom,15*zoom) ? (
#menu = "";
tmp_loop = 72;
loop(61,
(tmp_loop - 0)%12 == 0 ? #readouts = "C";
(tmp_loop - 0)%12 == 1 ? #readouts = "C#";
(tmp_loop - 0)%12 == 2 ? #readouts = "D";
(tmp_loop - 0)%12 == 3 ? #readouts = "D#";
(tmp_loop - 0)%12 == 4 ? #readouts = "E";
(tmp_loop - 0)%12 == 5 ? #readouts = "F";
(tmp_loop - 0)%12 == 6 ? #readouts = "F#";
(tmp_loop - 0)%12 == 7 ? #readouts = "G";
(tmp_loop - 0)%12 == 8 ? #readouts = "G#";
(tmp_loop - 0)%12 == 9 ? #readouts = "A";
(tmp_loop - 0)%12 == 10 ? #readouts = "Bb";
(tmp_loop - 0)%12 == 11 ? #readouts = "B";
sprintf(#readoutsoctave, "%i", (abs(tmp_loop)-12)/12   ); #readouts += #readoutsoctave;
this.note == tmp_loop ? #menu += "!";
#menu += #readouts;
#menu += "|";
tmp_loop -= 1;
);
last_clicked_item = gfx_showmenu(#menu);
last_clicked_item ? (last_clicked_item = 73-last_clicked_item; this.note = last_clicked_item);
);
gfx_drawstr(#readouts);
);

last_clicked_pad == this ? (


!fileopen && this.mode == 1 ? (
#readout = sprintf(#, "%.2f", ratio2db(slider(vol.slider)));
#readout += " dB";
#label1 = "VOL";
vol.addknob(170,170,170,0);
slider(pan.slider) == 0.5 ? (
#readout = "<C>";
) : slider(pan.slider) < 0.5 ? (
#readout = sprintf(#, "%.0f", 100 - 200*slider(pan.slider));
#readout += "L";
) : (
#readout = sprintf(#, "%.0f", 200*(slider(pan.slider)-0.5));
#readout += "R";
);
#label1 = "BAL";
pan.addknob(170,170,170,0);
#readout = sprintf(#, "%.0f", slider(semitones.slider));
