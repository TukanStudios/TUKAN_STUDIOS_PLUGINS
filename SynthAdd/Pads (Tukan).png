  gfx_line(box_x, box_y + 3*box_h/4 - tmp_loop, box_x+box_w, box_y + 3*box_h/4 - tmp_loop);
  gfx_line(box_x, box_y + 3*box_h/4 + tmp_loop, box_x+box_w, box_y + 3*box_h/4 + tmp_loop);
  tmp_loop += 1;
);
