this.mode == 2 ? (
Kick_Gain.parameter_config  (138,     0,        -24,  6,  445, 405, 115,  101,  1,  4);
Kick_Pan.parameter_config   (139,     0,         -1,  1,  505, 405, 115,  101,  1,  4);
