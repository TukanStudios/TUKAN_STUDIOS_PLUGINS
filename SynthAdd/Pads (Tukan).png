function pad_sliders() (
this.volume = slider(3 + 1 + (this-1)*7);
this.pan = slider(3 + 2 + (this-1)*7);
this.FadeInCurve = slider(3 + 3 + (this-1)*7);
this.FadeOutCurve = slider(3 + 4 + (this-1)*7);
this.FadeInCurve >= 5 ? this.FI_coef = 1+(this.FadeInCurve - 5)*2.5 : this.FI_coef = 0.1 + 0.9*(this.FadeInCurve/5);
this.FadeOutCurve >= 5 ? this.FO_coef = 1+(this.FadeOutCurve - 5)*2.5 : this.FO_coef = 0.1 + 0.9*(this.FadeOutCurve/5);
this.Semitones = slider(3 + 5 + (this-1)*7);
this.Cents = slider(3 + 6 + (this-1)*7);

this.release = slider(115+this);

this.solo ? gen_solo = 2;

  this.speed = 2^ ((this.semitones + (this.cents/100))/12);

this.Velocity = slider(3 + 7 + (this-1)*7);
);

