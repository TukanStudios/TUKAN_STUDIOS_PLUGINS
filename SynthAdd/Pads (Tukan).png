      function adsr_dragStart (_slider, _default)
                   (
                          yOld = mouse_y;xOld = mouse_x;
                           ctrl ? (
                              slider(_slider) = _default;caller = 1;
                           ):(
                           h_dragging = _slider;
                           gen_dragging = 1;
                           valold = slider(_slider);
                           );
                   );        
                           
                           

      function adsr_potDrag(_sliderh, _slidermax)
            local      (nachkomma)
                       (
                         //mstep = _slidermax/_sliderh;
                        Shift ? mstep = 0.1*72/_sliderh : mstep = 72/_sliderh;
                        val = valOld + (yOld - mouse_y) * mstep;
                        val = min(max(val, -60), _slidermax);
                        slider(h_dragging) = val;
                        slider_automate(slider(h_dragging));
                        caller = 1;
                );
                
                
function ADSRSlider (_sliderx, _slidery, _sliderh, _slider, _slidermax, _default, r_,g_,b_) local (_sliderpos) (
_sliderpos = _slidery - _sliderh* ((slider(_slider)+60)/72);
black(); gfx_a = 1;
gfx_rect(_sliderx+zoom*12, _slidery - _sliderh + 5*zoom, 4*zoom, _sliderh + 6*zoom);

rgb(r_,g_,b_);
gfx_x = _sliderx; gfx_y = _slidery + 17*zoom;
gfx_drawstr(#readout, 0x05, gfx_x+29*zoom, gfx_y + 20*zoom);


gfx_x = _sliderx; gfx_y = _sliderpos;
gfx_blit(5,zoom*0.5,0);



confirm_me == 0 && mouseClick == 1 ? (
g_collision(gfx_x, gfx_y, 29*zoom, 14*zoom) ? adsr_dragstart(_slider, _default);
);

mouseclick == -1 ? (
h_dragging = 0;
);

h_dragging == _slider ? adsr_potdrag(_sliderh, _slidermax);

);


gfx_a = 1;
gfx_x=box_x-15*zoom; gfx_y = box_y-15*zoom;
gfx_blit(6,0.5*zoom,0);
gfx_a = 1;

function mixer_stuff() (
black(); gfx_rect(box_x+10*zoom+ (this-1)*slider_dist, box_y+54*zoom, 8*zoom, 138*zoom);
this.clip ? rgb(255,30,100) : rgb(30,255,100); gfx_x = box_x+10*zoom+ (this-1)*slider_dist; gfx_y = box_y+193*zoom;
gfx_rectto(gfx_x+8*zoom,max(min(gfx_y,box_y+54*zoom-180*ratio2db(this.outmeter)/60),box_y+54*zoom));

this.mute == 1 ? (rgb(255,20,20);fill = 1) : (rgb(140,140,140);fill=0);
gfx_rect(gfx_x = box_x+27*zoom+ (this-1)*slider_dist, gfx_y=155*zoom, 15*zoom,15*zoom,fill);
confirm_me == 0 && mouseClick == 1 && g_collision(gfx_x,gfx_y, 15*zoom,15*zoom) ? (this.mute == 1 ? this.mute = 0 : this.mute = 1; caller = 1; soundless = 1);
this.mute ? white() : black(); 
gfx_x += 2*zoom; gfx_drawstr("M");
this.solo == 1 ? (rgb(255,255,20);fill=1) : (rgb(140,140,140);fille=0);
gfx_rect(gfx_x = box_x+7*zoom+ (this-1)*slider_dist, gfx_y=155*zoom, 15*zoom,15*zoom,fill);
confirm_me == 0 && mouseClick == 1 && g_collision(gfx_x,gfx_y, 15*zoom,15*zoom) ? (this.solo == 1 ? this.solo = 0 : this.solo = 1; caller = 1; soundless = 1);
black(); 
gfx_x += 3*zoom; gfx_drawstr("S");

gfx_x = box_x+10*zoom+ (this-1)*slider_dist; gfx_y=135*zoom;
gfx_drawstr("P ");
this < 10 ? gfx_drawstr("0");
gfx_drawnumber(this,0);
);


view == 1 || (cur_mode != 1 && view < 2) ? (
