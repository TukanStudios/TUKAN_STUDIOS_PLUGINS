function draw_wave(x, y, w, h, buf, len)
local(i, _x, _y)
(
  //set_color(COLOR_ACTIVE);
  zoom_len = len / (box_hzoom*19 + 1);
  zoom_buf = buf + 2*box_scroll * (len - zoom_len);
  loop(i = 0; zoom_len,
    _x = 0.5*i * w / zoom_len + x;
    _y = box_vzoom * -zoom_buf[i] * h / 2 + h / 2 + y;
    i == 0 ? (
      gfx_x = _x;
      gfx_y = _y;
    );
    gfx_lineto(_x, min(y+h, max(y,_y)));
    i += 2;
  );
  box_time = (zoom_len/2)/srate;
  box_start = (zoom_buf-buf)/srate;
  box_time_samples = (zoom_len/2);
  box_start_samples = (zoom_buf-buf);
);

function handle_highlight(col_, highlight_) (
  highlight_ ? gfx_a = 1 : gfx_a = 0.5;
  col_ == 1 ? rgb(255,0,255);  col_ == 2 ? rgb(100,255,100);
);

function box_color() (
  white();
);



function draw_handle(x, y, w, h, buf, len)
local(i, _x, _y)
(
  //set_color(COLOR_ACTIVE);
this.start_handle < floor(box_start_samples/4) ? start_handle_x = box_x;
this.start_handle > floor(zoom_len/2 + box_start_samples/4) ? start_handle_x = box_x+box_w;
this.stop_handle < floor(box_start_samples/4) ? stop_handle_x = box_x;
this.stop_handle > floor(zoom_len/2 + box_start_samples/4) ? stop_handle_x = box_x+box_w;

this.start_handle+this.fade_in_handle < floor(box_start_samples/4) ? fade_in_handle_x = box_x;
this.start_handle+this.fade_in_handle > floor(zoom_len/2 + box_start_samples/4) ? fade_in_handle_x = box_x+box_w;
this.stop_handle-this.fade_out_handle < floor(box_start_samples/4) ? fade_out_handle_x = box_x;
this.stop_handle-this.fade_out_handle > floor(zoom_len/2 + box_start_samples/4) ? fade_out_handle_x = box_x+box_w;

  zoom_len = len / (box_hzoom*19 + 1);
  zoom_buf = buf + 2*box_scroll * (len - zoom_len);
  loop(i = 0; zoom_len,
    _x = 0.5*i * w / zoom_len + x;
    
    box_color();
    floor((i/4)+box_start_samples/4) == this.start_handle ? (
        g_collision(box_x, box_y+ box_h -box_handle_size-1, box_w, box_handle_size) ? highlight = 1 : highlight = 0;
        handle_highlight(1, highlight);
        gfx_rect(_x, box_y+1, 2*zoom, box_h-1);
        gfx_rect(start_handle_x = _x, start_handle_y = box_y+ box_h -box_handle_size-1, box_handle_size, box_handle_size,0);
        cur_start_handle = this.start_handle;
    );
    
    floor((i/4)+box_start_samples/4) == this.start_handle+this.fade_in_handle ? (
        g_collision(box_x, box_y+ box_h/2, box_w, box_h/4) ? highlight = 1 : highlight = 0;
        handle_highlight(1, highlight);
        gfx_rect(fade_in_handle_x = _x, box_y+1, 2*zoom, (box_h/9));
        gfx_rect(_x, box_y+(2*box_h/9), 2*zoom, (box_h/9));
        gfx_rect(_x, box_y+(4*box_h/9), 2*zoom, (box_h/9));
        gfx_rect(_x, box_y+(6*box_h/9), 2*zoom, (box_h/9));
        gfx_rect(_x, box_y+(8*box_h/9), 2*zoom, (box_h/9));
    );
    
    floor((i/4)+box_start_samples/4)+1 == this.stop_handle ? (
        g_collision(box_x, box_y+1, box_w, box_handle_size) ? highlight = 1 : highlight = 0;
        handle_highlight(2, highlight);
        gfx_rect(stop_handle_x = _x - zoom, box_y+1, 2*zoom, box_h-1);
        gfx_rect(_x - box_handle_size, stop_handle_y = box_y+1, box_handle_size, box_handle_size,0);
        cur_stop_handle = this.start_handle;
    );
    
    floor((i/4)+box_start_samples/4) == this.stop_handle-this.fade_out_handle ? (
        g_collision(box_x, box_y+ box_h/4, box_w, box_h/4) ? highlight = 1 : highlight = 0;
        handle_highlight(2, highlight);
        gfx_rect(fade_out_handle_x = _x, box_y+1, 2*zoom, (box_h/9));
        gfx_rect(_x, box_y+(2*box_h/9), 2*zoom, (box_h/9));
        gfx_rect(_x, box_y+(4*box_h/9), 2*zoom, (box_h/9));
        gfx_rect(_x, box_y+(6*box_h/9), 2*zoom, (box_h/9));
        gfx_rect(_x, box_y+(8*box_h/9), 2*zoom, (box_h/9));
    );
    
    i += 2;
  );
  
  start_handle_x > box_x ? (
    gfx_a = 0.5;
    rgb(120,120,120); gfx_x = box_x; gfx_y = box_y;
    gfx_rectto(start_handle_x, box_y+box_h);
  );
  stop_handle_x < box_x+box_w ? (
    gfx_a = 0.5;
    rgb(120,120,120); gfx_x = box_x+box_w; gfx_y = box_y;
    gfx_rectto(stop_handle_x, box_y+box_h);
  );
  
  handle_highlight(1,0);
  this.fade_in_handle > 0 ? (
    start_x = 0.5* ((this.start_handle)*4-box_start_samples) * w / zoom_len + x;
    fade_in_x = 0.5* ((this.start_handle+this.fade_in_handle)*4-box_start_samples) * w / zoom_len + x;
    gfx_fade_in = fade_in_x - start_x;
    gfx_x = start_x; gfx_y = box_y + box_h;
    tmp_loop = 0;
    loop(gfx_fade_in,
      cur_value = -1*explog(1-(tmp_loop / gfx_fade_in), this.FI_coef)+1;
      start_x+tmp_loop >= box_x && start_x+tmp_loop <= box_x + box_w ? gfx_rectto(start_x+tmp_loop+zoom*2, box_y + box_h - box_h*cur_value -zoom);
      gfx_x = start_x+tmp_loop; gfx_y = box_y + box_h - box_h*cur_value;
      tmp_loop += 1;
    );
  );
  
  handle_highlight(2,0);
  this.fade_out_handle > 0 ? (
    stop_x = 0.5* ((this.stop_handle)*4-box_start_samples) * w / zoom_len + x;
    fade_out_x = 0.5* ((this.stop_handle-this.fade_out_handle)*4-box_start_samples) * w / zoom_len + x;
    gfx_fade_out = stop_x - fade_out_x;
    gfx_x = fade_out_x; gfx_y = box_y;
    tmp_loop = 0;
    loop(gfx_fade_out,
      cur_value = explog(tmp_loop / gfx_fade_out, this.FO_coef);;
      fade_out_x+tmp_loop >= box_x && fade_out_x+tmp_loop <= box_x + box_w ? gfx_rectto(fade_out_x+tmp_loop+zoom*2, box_y + box_h*cur_value+zoom);
      gfx_x = fade_out_x+tmp_loop; gfx_y = box_y + box_h*cur_value;
      tmp_loop += 1;
    );
  );
  
);





