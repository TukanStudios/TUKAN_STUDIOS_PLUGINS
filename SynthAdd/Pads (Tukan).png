function tt() (
  #tooltip += "Pad ";
  this < 10 ? #tooltip += "0";
  #tooltip += sprintf(#, "%i", this);
  #tooltip += " - ";
  this.mode == 0 ? #tooltip += "empty";
  this.mode == 1 ? #tooltip += this.name;
  this.mode == 2 ? #tooltip += "Synth Kick";
  this.mode == 3 ? #tooltip += "Synth Snare";
  this.mode == 4 ? #tooltip += "Synth Clap";
  this.mode == 5 ? #tooltip += "Synth Cymbal";
  this.mode == 6 ? #tooltip += "Synth Closed Hihat";
  this.mode == 7 ? #tooltip += "Synth Open Hihat";
  this.mode == 8 ? #tooltip += "Synth Low Tom";
  this.mode == 9 ? #tooltip += "Synth Mid Tom";
  this.mode ==10 ? #tooltip += "Synth High Tom";
  this.mode ==11 ? #tooltip += "Synth Rim";
  this.mode ==12 ? #tooltip += "Synth Cowbell";
  this.mode ==13 ? #tooltip += "Synth Shaker";
  this.mode == -1 ? (
  #tooltip += "Missing: ";
  #tooltip += this.name;
  );
);

