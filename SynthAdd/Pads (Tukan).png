  last_clicked_item ==10 ? (S_T1 == 0 ? this.mode = 10; S_T1 = this):
  last_clicked_item ==11 ? (S_Rim == 0 ? this.mode = 11; S_Rim = this):
  last_clicked_item ==11 ? (S_CB == 0 ? this.mode = 11; S_CB = this):
  last_clicked_item ==12 ? (S_Shaker == 0 ? this.mode = 12; S_Shaker = this) ;
  last_clicked_item < 2 ? (
    S_BD == this ? S_BD = 0 :
    S_SN == this ? S_SN = 0 :
    S_Clap == this ? S_Clap = 0 :
    S_cym == this ? S_Cym = 0 :
